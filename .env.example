# ExecFlex Backend Environment Variables
# Copy this file to .env and fill in your actual values
# 
# IMPORTANT: Never commit .env to git (it's in .gitignore)

# ============================================================================
# REQUIRED - Core Functionality
# ============================================================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
# Must be the **service role key** (has admin access), not the anon key
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Email Configuration (for sending introduction emails)
EMAIL_USER=your-email@gmail.com
# Must be an **app password** if using Gmail with 2FA
EMAIL_PASS=your-app-password-here

# Server Port usually auto-set by platform (onrender)
# For local development, default is 5001
# PORT=5001

# ============================================================================
# OPTIONAL - Email Configuration
# ============================================================================

# SMTP Configuration (optional - uses Gmail defaults if not set)
# Only needed if using non-Gmail SMTP server
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=465

# ============================================================================
# OPTIONAL - Voice/Telephony Features
# ============================================================================

# Twilio Configuration (required for voice calls)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Must be in E.164 format (starts with `+`, includes country code)
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# OPTIONAL - Text-to-Speech Features
# ============================================================================

# ElevenLabs Configuration (required for TTS in voice calls)
# ELEVEN_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELEVEN_VOICE_ID=your-voice-id-here

# ============================================================================
# OPTIONAL - AI Conversation Features
# ============================================================================

# OpenAI Configuration (required for GPT conversation rephrasing)
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OPTIONAL - Stripe Billing
# ============================================================================

# Stripe Configuration (required for billing/subscription features)
# Use test keys during development (from Stripe Dashboard → API keys)
# STRIPE_SECRET_KEY=your-stripe-secret-key-here
# STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
# Growth tier price ID (create in Stripe Dashboard: €299/month recurring)
# STRIPE_GROWTH_PRICE_ID=your-stripe-price-id-here

# ============================================================================
# SECURITY - Authentication & Authorization
# ============================================================================

# JWT signature verification (Supabase Dashboard → Settings → API → JWT Secret)
# REQUIRED for production — without this, JWTs are decoded without signature checks
# SUPABASE_JWT_SECRET=your-jwt-secret-here

# Service-to-service auth key (Ainm backend → ExecFlex)
# Shared secret — set the same value in Ainm's config as EXECFLEX_SERVICE_KEY
# AINM_SERVICE_KEY=generate-a-strong-random-secret-here

# Smoke test bypass for CI/CD pipelines
# SMOKE_TEST_BYPASS_SECRET=your-smoke-test-secret
# SMOKE_TEST_USER_ID=a-valid-user-uuid

# ============================================================================
# OPTIONAL - App Configuration
# ============================================================================

# Environment (dev/prod)
# APP_ENV=dev
# Auto configured by
# PYTHON_VERSION=

# ============================================================================
# OPTIONAL - Apollo.io Candidate Sourcing
# ============================================================================
# Apollo API key (Apollo Dashboard → Settings → API)
# If unset, /post-role will silently skip candidate sourcing.
# APOLLO_API_KEY=your-apollo-api-key-here
